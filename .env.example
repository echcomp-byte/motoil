# Copy to .env and fill in. Only EXPO_PUBLIC_* leaks to the client bundle.

# Supabase (set in Day 2)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the public rescue page (web/, deployed to Vercel).
# QR codes embed `${EXPO_PUBLIC_QR_BASE_URL}/p/<token>`.
# Phase 1: a vercel.app preview URL. Phase 2: ice.motoil.app or similar.
# Falls back to https://ice.motoil.app in src/features/qr/qrUrl.ts when unset.
EXPO_PUBLIC_QR_BASE_URL=https://ice-motoil.vercel.app

# Google OAuth (Day 4)
# Create both in Google Cloud Console → APIs & Services → Credentials:
#   - iOS Client ID:  must match app.json ios.bundleIdentifier (com.echcomp.motoil)
#   - Web Client ID:  also pasted in Supabase Dashboard → Auth → Providers → Google
# Scopes: openid email profile
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-abc.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xyz.apps.googleusercontent.com

# Apple OAuth (Day 4)
# No env vars — credentials flow through Apple Developer Portal entitlements
# and Supabase Dashboard → Auth → Providers → Apple (client_id = bundle id, secret = JWT).

# PostHog analytics (Phase 1 — Dev D)
# EU cloud — matches Supabase eu-west-3 residency.
# Project API Key (phc_…) is a public write-only key; safe in client bundle.
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_key
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry crash reporting (Phase 1 — Dev D)
# DSN is public write-only; safe in client bundle.
# SENTRY_AUTH_TOKEN is server-side only (GitHub Secrets, never in client) — see docs/CI_SECRETS.md.
EXPO_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project
