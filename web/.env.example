# Public base URL for the rescue page — printed on QR stickers in the RN app.
# Set to the deployed origin (vercel.app subdomain in Phase 1, custom domain later).
NEXT_PUBLIC_SITE_URL=https://ice-motoil.vercel.app

# Supabase project URL (same project as RN app). Used to call public-profile Edge Function.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — safe to ship to the browser. Service-role key MUST NEVER appear here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
